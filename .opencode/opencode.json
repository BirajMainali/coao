{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/AGENTS.md",
    ".opencode/rules/behavior/*.md",
    ".opencode/rules/governance/*.md",
    ".opencode/rules/operations/*.md"
  ],
  "mcp": {
    "serena": {
      "type": "local",
      "command": ["serena", "start-mcp-server", "--context=ide", "--open-web-dashboard=false"]
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "fixture-mcp": {
      "type": "local",
      "command": ["fixture-mcp", "--serve"],
      "environment": {
        "FIXTURE_DB_PATH": ".opencode/.fixture.db"
      }
    }
  }
}
